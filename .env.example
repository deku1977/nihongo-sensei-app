# Google Cloud API Keys
# Ottieni le chiavi da: https://console.cloud.google.com/

# Text-to-Speech API (per generazione audio)
VITE_GOOGLE_TTS_API_KEY=your_tts_api_key_here

# Translation API (per traduzioni automatiche)
VITE_GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here

# Note: Rinomina questo file in .env per usare le API
